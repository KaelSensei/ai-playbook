# Copy this file to `.env` and edit. Never commit `.env`.

# Optional API key for headless auth. Leave commented to use OAuth on first
# `claude` run (login persists in the `claude-config` named volume).
# ANTHROPIC_API_KEY=sk-ant-...

# Host directory mounted at /workspace inside the container.
# Default: ./workspace (a local subdir — good for general use).
# To dogfood the ai-playbook repo itself, set:
#   WORKSPACE=../..
WORKSPACE=./workspace

# UID/GID for the in-container `dev` user. Leave empty unless you know you
# need to override; the Makefile auto-detects your host UID/GID.
# USER_UID=1000
# USER_GID=1000
