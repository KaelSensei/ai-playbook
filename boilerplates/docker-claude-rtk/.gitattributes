# Force LF for files consumed by Linux containers.
# Without this, Windows checkouts produce CRLF and break the entrypoint shebang.
*.sh         text eol=lf
Dockerfile   text eol=lf
entrypoint.* text eol=lf
Makefile     text eol=lf
compose.yaml text eol=lf
.env.example text eol=lf
.dockerignore text eol=lf

# PowerShell stays CRLF on Windows (it's run on the host, not in the container).
*.ps1        text eol=crlf
