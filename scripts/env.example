# Autonomous setup — environment template
#
# Copy this file to `.env.local` at the repo root, chmod 600 it, and fill in
# ONLY the tokens you plan to use. Every other line can stay blank.
#
#   cp scripts/env.example .env.local
#   chmod 600 .env.local
#   $EDITOR .env.local
#
# .env.local is already covered by .gitignore. Do not commit real tokens.
# Do not paste any of these values into chat, PR bodies, commit messages,
# or issue comments.
#
# See AUTONOMOUS_SETUP.md for scope requirements for each token.

# --- GitHub ---------------------------------------------------------------
# Required by /auto and by `gh` CLI. Minimum scope: repo (RW), read:org.
# Fine-grained tokens: Contents:RW + Pull requests:RW on the target repos.
# DO NOT grant admin, workflow, or delete_repo.
GITHUB_TOKEN=

# --- Anthropic (Claude Code, primary) ------------------------------------
# Used by Claude Code CLI. Set spending limits in the Anthropic console.
ANTHROPIC_API_KEY=

# --- OpenAI (Codex CLI, Aider) -------------------------------------------
# Used by Codex CLI and optionally by Aider. Set spending limits.
OPENAI_API_KEY=

# --- Google (Gemini CLI) -------------------------------------------------
# Optional, only if you plan to use Gemini CLI.
GEMINI_API_KEY=

# --- Which CLIs should `setup-autonomous.sh` try to install? -------------
# Set to 1 to opt in, leave blank or 0 to skip. The script never installs
# a tool without an opt-in here.
INSTALL_CLAUDE_CODE=1
INSTALL_CODEX_CLI=0
INSTALL_GEMINI_CLI=0
INSTALL_AIDER=0
